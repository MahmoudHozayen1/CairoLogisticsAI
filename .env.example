# Copy this file to ".env" and adjust values. python-dotenv loads it automatically.

# Flask
FLASK_CONFIG=development
SECRET_KEY=change-this-to-a-long-random-string

# Database
# Leave DATABASE_URL unset to use the bundled SQLite file (zero-config).
# For PostgreSQL (see docker-compose.yml):
# DATABASE_URL=postgresql+psycopg2://swiftroute:swiftroute@localhost:5432/swiftroute

# Routing engine
# Set to 1 to enable OSMnx street-following routes (requires the optional
# scientific dependencies in requirements.txt and internet access).
ENABLE_STREET_ROUTING=0
SERVICE_CENTER_LAT=29.9602
SERVICE_CENTER_LON=31.2569
SERVICE_RADIUS_M=5000

# Street-following geometry + traffic colours.
#   osrm     -> follow real roads via a public OSRM server (default, no API key)
#   straight -> straight lines only (fully offline)
#   osmnx    -> use a local street graph (heavy, optional)
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=https://router.project-osrm.org
ROUTING_TIMEOUT=6

# Admin operations assistant (chatbot)
# The assistant ALWAYS works offline by retrieving answers from the database.
# When an Ollama server is reachable it also phrases replies with an LLM,
# grounded strictly on the retrieved facts. Set ASSISTANT_USE_LLM=0 to force the
# deterministic offline responder (e.g. on hosting with no Ollama).
ASSISTANT_USE_LLM=1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=20
